# Output/Appearance
font=JetBrainsMono Nerd Font:size=12
icon-theme=Papirus-Dark
prompt=" "
terminal=alacritty # or your preferred terminal
launch-prefix="uwsm app -- " # Optional: for UWSM users

[colors]
background=1e1e2eff
text=cdd6f4ff
match=f38ba8ff
selection=585b70ff
